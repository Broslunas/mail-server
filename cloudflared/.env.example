# Cloudflare Tunnel Environment Variables
# Generated by: cloudflared tunnel login && cloudflared tunnel create webmail

TUNNEL_ID=your-tunnel-uuid-here

# Public hostname for the webmail (must match the CNAME in Cloudflare DNS)
WEBMAIL_DOMAIN=mail.example.com

# Subdomain for the WildDuck REST API (exposed to the Next.js webmail)
API_SUBDOMAIN=imap-api
PUBLIC_ROOT_DOMAIN=example.com
