# Secrets and runtime data — NEVER commit
.env
.env.local
.env.production
*.env
!.env.example

# TLS certificates (regenerated by setup-oracle.sh)
wildduck/tls/*.crt
wildduck/tls/*.key
wildduck/tls/*.pem
!wildduck/tls/.gitkeep

# DKIM private keys (regenerated by setup-oracle.sh)
wildduck/dkim/*.pem
!wildduck/dkim/.gitkeep

# Cloudflare Tunnel credentials (per-tunnel secret)
cloudflared/*.json
!cloudflared/.gitkeep

# Node / build artifacts
node_modules/
.next/
dist/
build/

# OS / editor junk
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
logs/

# Generated by setup
docker-compose.override.yml
