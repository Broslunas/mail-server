# ============================================================
# WildDuck Mail Server — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit the .env file.
# ============================================================

# Public FQDN clients will use to connect (CNAME of the Cloudflare Tunnel)
# e.g. mail.broslunas.com
MAIL_FQDN=mail.example.com

# Public origin of your Next.js webmail (for CORS on WildDuck API)
WEBMAIL_DOMAIN=mail.example.com

# ---------------------------------------------------------
# MongoDB Atlas (free M0 tier) — used by WildDuck AND the webmail
# ---------------------------------------------------------
# Same connection string as in your Next.js .env.local
MONGODB_USER=mailuser
MONGODB_PASS=change_me
MONGODB_HOST=cluster0.xxxxx.mongodb.net
MONGODB_DB=mailservice

# ---------------------------------------------------------
# WildDuck REST API key
# Generate with: openssl rand -hex 32
# Must match the value configured in Next.js .env.local
# ---------------------------------------------------------
WILDDUCK_API_KEY=replace_with_openssl_rand_hex_32

# ---------------------------------------------------------
# Mailbox defaults
# ---------------------------------------------------------
# 100 MB default quota
DEFAULT_QUOTA=104857600
# Max messages per mailbox
DEFAULT_MAX_MESSAGES=50000
